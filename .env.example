# LLM Provider Configuration
# Supported providers: openai, gemini, or any standard openai-compatible endpoint
LLM_PROVIDER=openai

# Model identifier (e.g., gpt-4o, gemini-2.5-flash, deepseek-chat)
# Defaults to gpt-4o if not specified here.
LLM_MODEL=gpt-4o

# API Key for the selected provider
LLM_API_KEY=your-api-key-here

# Optional: Base URL if using an OpenAI-compatible endpoint (e.g. Gemini, DeepSeek, Ollama, Together)
# For Gemini OpenAI Compatibility (use your Gemini API Key as LLM_API_KEY):
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# For local Ollama:
# LLM_BASE_URL=http://localhost:11434/v1
LLM_BASE_URL=

# Optional: Performance pricing parameters (USD per 1M tokens) for perf reports
LLM_INPUT_PRICE_PER_1M=0.15
LLM_OUTPUT_PRICE_PER_1M=0.60

# Optional: Pricing parameters for baseline model comparison in perf reports
BASELINE_MODEL_NAME=GPT-4o (proxy)
BASELINE_INPUT_PRICE_PER_1M=2.50
BASELINE_OUTPUT_PRICE_PER_1M=10.00
